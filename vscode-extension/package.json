{
  "name": "prettier-catspeak",
  "displayName": "Prettier Formatter: Catspeak",
  "description": "A code formatter for Catspeak built with Prettier",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "catspeak",
    "prettier-plugin",
    "prettier",
    "formatter"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "type": "module",
  "dependencies": {
    "@harlem512/prettier-plugin-catspeak": "file:..",
    "prettier": "^3.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "languages": [
      {
        "id": "catspeak",
        "aliases": [
          "Catspeak",
          "catspeak",
          "sp",
          "meow"
        ],
        "extensions": [
          ".meow",
          ".catspeak"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/catspeak-logo-light.svg",
          "dark": "./icons/catspeak-logo-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "catspeak",
        "scopeName": "source.catspeak",
        "path": "./syntaxes/catspeak.tmLanguage.json"
      },
      {
        "scopeName": "text.html.markdown.codeblock.catspeak",
        "path": "./syntaxes/codeblock.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.catspeak": "catspeak"
        }
      }
    ]
  }
}