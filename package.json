{
  "name": "@harlem512/prettier-plugin-catspeak",
  "version": "0.4.0",
  "description": "A Prettier plugin for Catspeak",
  "keywords": [
    "catspeak",
    "prettier-plugin",
    "prettier",
    "formatter"
  ],
  "homepage": "https://github.com/Harlem512/prettier-plugin-catspeak#readme",
  "bugs": {
    "url": "https://github.com/Harlem512/prettier-plugin-catspeak/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harlem512/prettier-plugin-catspeak.git"
  },
  "license": "MIT",
  "author": "Harlem512",
  "type": "commonjs",
  "exports": {
    ".": "./out/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b --declaration",
    "extension-package": "npm run build && cd vscode-extension && npm run package",
    "extension-watch": "npm run build && cd vscode-extension && npm run watch",
    "extension-build": "npm run build && cd vscode-extension && npm run build",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest"
  },
  "dependencies": {
    "prettier": "^3.8.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "jest": "^30.4.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}